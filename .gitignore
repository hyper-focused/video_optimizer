# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Editor / OS
.vscode/
.idea/
.DS_Store
.claude/

# Project state (created at runtime by the tool)
.video_optimizer/
state.db
state.db-wal
state.db-shm

# Run logs (archive.sh, optimize, ad-hoc test runs — all .log in this repo
# are run output, never source). The conventional landing spot is the
# top-level `logs/` directory; the bare `*.log` pattern is the
# belt-and-braces fallback for stragglers landing elsewhere.
logs/
*.log

# Local one-shot recovery scripts (not project code)
clear.py
cleanup.py
fix_*.py
audit_*.py
# Exception: audit_orphans.py is a committed periodic-spot-check tool,
# not a one-off — see README.
!audit_orphans.py

# ffmpeg arg-parsing artifact: bare 'dovi_rpu=strip=true' on a CLI
# without -bsf:v: gets created as an output file. Belt-and-braces.
dovi_rpu=strip=true
